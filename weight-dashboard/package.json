{
	"name": "weight-dashboard",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"main": "main.cjs",
	"author": "Saqib Silk Industry",
	"description": "Weight Dashboard for Saqib Silk Industry - Desktop Application",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"electron": "electron .",
		"electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
		"electron-build": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder",
		"electron-pack": "npm run build && electron-builder --dir",
		"clear-cache": "rmdir /s /q \"%LOCALAPPDATA%\\electron-builder\\Cache\\winCodeSign\" 2>nul || echo Cache cleared",
		"build:win": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --x64"
	},
	"dependencies": {
		"@serialport/parser-readline": "^12.0.0",
		"escpos": "^3.0.0-alpha.6",
		"escpos-usb": "^3.0.0-alpha.4",
		"fs-extra": "^11.3.2",
		"html2canvas": "^1.4.1",
		"jspdf": "^3.0.3",
		"qrcode": "^1.5.4",
		"qrcode.react": "^4.2.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-router-dom": "^6.30.1",
		"recharts": "^2.12.7",
		"serialport": "^12.0.0",
		"googleapis": "^144.0.0"
	},
	"devDependencies": {
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.7.0",
		"autoprefixer": "^10.4.20",
		"concurrently": "^8.2.2",
		"electron": "^30.0.0",
		"electron-builder": "^24.13.3",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.14",
		"vite": "^5.4.8",
		"wait-on": "^7.2.0"
	},
	"build": {
		"appId": "com.weight.dashboard",
		"productName": "Weight Dashboard",
		"directories": {
			"output": "release"
		},
		"asar": true,
		"asarUnpack": [
			"**/node_modules/serialport/**/*",
			"**/node_modules/@serialport/**/*"
		],
		"files": [
			"dist/**/*",
			"main.cjs",
			"preload.cjs",
			"main/**/*",
			"package.json",
			"!src/**/*",
			"!*.md",
			"!*.config.js",
			"!tailwind.config.js",
			"!postcss.config.js",
			"!vite.config.js",
			"!electron-builder.yml",
			"!node_modules/@types/**/*",
			"!node_modules/.bin/**/*",
			"!node_modules/**/*.{md,ts,map}",
			"!node_modules/**/test/**/*",
			"!node_modules/**/tests/**/*",
			"!node_modules/**/__tests__/**/*"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"sign": false,
			"signingHashAlgorithms": []
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"deleteAppDataOnUninstall": false
		}
	}
}
